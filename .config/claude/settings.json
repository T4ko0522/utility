{
  "autoUpdatesChannel": "stable",
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Read(.env.example)",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "mcp__chrome-devtools",
      "mcp__serena",
      "mcp__playwright"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(rm -rf:*)",
      "Bash(chmod 777:*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Read(.env.development)",
      "Read(**/credentials.json)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Write(.env*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File $USERPROFILE/.claude/claude_notify.ps1",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
